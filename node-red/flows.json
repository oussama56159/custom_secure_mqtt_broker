    {
        "id": "p3_in_dashboard",
        "type": "mqtt in",
        "z": "phase3_tab",
        "name": "Subscribe sensors/#",
        "topic": "sensors/#",
        "qos": "0",
        "datatype": "auto-detect",
        "broker": "p3_mqtt_dashboard",
        "x": 170,
        "y": 420,
        "wires": [
            [
                "p3_fn_process"
            ]
        ]
    },
    {
        "id": "p3_fn_process",
        "type": "function",
        "z": "phase3_tab",
        "name": "Process sensors + stats + alerts",
        "func": "let data = msg.payload;\nif (typeof data === \"string\") {\n    try { data = JSON.parse(data); } catch (e) { return [null, null, null, null, null, null, null]; }\n}\nconst now = Date.now();\nconst topic = msg.topic || \"\";\nlet tempVal = null;\nlet humVal = null;\nif (topic.includes(\"temperature\")) {\n    tempVal = data.temperature_c;\n    const lastSeen = flow.get(\"lastSeen\") || {};\n    lastSeen.temperature = now;\n    flow.set(\"lastSeen\", lastSeen);\n} else if (topic.includes(\"humidity\")) {\n    humVal = data.humidity;\n    const lastSeen = flow.get(\"lastSeen\") || {};\n    lastSeen.humidity = now;\n    flow.set(\"lastSeen\", lastSeen);\n} else {\n    return [null, null, null, null, null, null, null];\n}\nconst HOUR = 3600000;\nlet hist = flow.get(\"history\") || { temp: [], hum: [] };\nfunction addHist(arr, val) {\n    arr.push({ x: now, y: val });\n    while (arr.length && (now - arr[0].x) > HOUR) arr.shift();\n}\nif (tempVal !== null) addHist(hist.temp, tempVal);\nif (humVal !== null) addHist(hist.hum, humVal);\nflow.set(\"history\", hist);\nlet stats = flow.get(\"stats\") || {\n    temp: { min: null, max: null, sum: 0, count: 0 },\n    hum: { min: null, max: null, sum: 0, count: 0 }\n};\nfunction updStats(s, val) {\n    s.count++;\n    s.sum += val;\n    s.min = s.min === null ? val : Math.min(s.min, val);\n    s.max = s.max === null ? val : Math.max(s.max, val);\n}\nif (tempVal !== null) updStats(stats.temp, tempVal);\nif (humVal !== null) updStats(stats.hum, humVal);\nflow.set(\"stats\", stats);\nfunction fmtStats(name, s, unit) {\n    if (!s.count) return name + \": waiting for data\";\n    return name + \": min=\" + s.min + unit + \"  max=\" + s.max + unit + \"  avg=\" + (s.sum / s.count).toFixed(1) + unit;\n}\nconst alerts = [];\nif (tempVal !== null) {\n    if (tempVal > 30) alerts.push(\"<span style='color:#ff5252;font-weight:bold'>&#9888; HIGH TEMP: \" + tempVal + \" deg C (threshold 30 deg C)</span>\");\n    if (tempVal < 15) alerts.push(\"<span style='color:#448aff;font-weight:bold'>&#9888; LOW TEMP: \" + tempVal + \" deg C (threshold 15 deg C)</span>\");\n}\nif (humVal !== null) {\n    if (humVal > 70) alerts.push(\"<span style='color:#ff5252;font-weight:bold'>&#9888; HIGH HUMIDITY: \" + humVal + \"% (threshold 70%)</span>\");\n    if (humVal < 30) alerts.push(\"<span style='color:#448aff;font-weight:bold'>&#9888; LOW HUMIDITY: \" + humVal + \"% (threshold 30%)</span>\");\n}\nconst alertMsg = { payload: alerts.length ? alerts.join(\"<br>\") : \"<span style='color:#00b500'>&#10003; All values within thresholds</span>\" };\nlet msgLog = flow.get(\"msgLog\") || [];\nconst ts = new Date(now).toLocaleTimeString();\nmsgLog.unshift(\"[\" + ts + \"] \" + topic + \" -> \" + JSON.stringify(data));\nif (msgLog.length > 40) msgLog = msgLog.slice(0, 40);\nflow.set(\"msgLog\", msgLog);\nconst tempGauge = tempVal !== null ? { payload: tempVal } : null;\nconst humGauge = humVal !== null ? { payload: humVal } : null;\nconst tempChart = tempVal !== null ? { payload: [{ series: [\"Temperature °C\"], data: [hist.temp.slice()], labels: [\"\"] }] } : null;\nconst humChart = humVal !== null ? { payload: [{ series: [\"Humidity %\"], data: [hist.hum.slice()], labels: [\"\"] }] } : null;\nconst statsMsg = { payload: fmtStats(\"Temperature\", stats.temp, \"°C\") + \"<br>\" + fmtStats(\"Humidity\", stats.hum, \"%\") };\nconst logMsg = { payload: msgLog.join(\"<br>\") };\nreturn [tempGauge, humGauge, tempChart, humChart, statsMsg, alertMsg, logMsg];",
        "outputs": 7,
        "noerr": 0,
        "x": 450,
        "y": 420,
        "wires": [
            [
                "p3_gauge_temp"
            ],
            [
                "p3_gauge_hum"
            ],
            [
                "p3_chart_temp"
            ],
            [
                "p3_chart_hum"
            ],
            [
                "p3_text_stats"
            ],
            [
                "p3_text_alerts"
            ],
            [
                "p3_fn_gate_msglog"
            ]
        ]
    },
