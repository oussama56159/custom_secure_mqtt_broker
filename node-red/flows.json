        "func": "flow.set(\"session\", null);\nreturn {\n    payload: {\n        tab: {\n            show: [\"p3_ui_tab_login\"],\n            hide: [\"p3_ui_tab_dashboard\", \"p3_ui_tab_charts\", \"p3_ui_tab_messages\", \"p3_ui_tab_security\", \"p3_ui_tab_logs\"]\n        }\n    }\n};",
