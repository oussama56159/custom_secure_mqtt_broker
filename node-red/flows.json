        "type": "function",
        "z": "phase3_tab",
        "name": "Build humidity payload",
        "func": "const value = Number((40 + Math.random() * 30).toFixed(1));\nmsg.topic = \"sensors/humidity\";\nmsg.payload = JSON.stringify({\n    sensor: \"humidity_sensor\",\n    humidity: value,\n    timestamp: new Date().toISOString()\n});\nreturn msg;",
        "outputs": 1,
