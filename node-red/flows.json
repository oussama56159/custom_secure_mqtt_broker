    {
        "id": "p3_fn_conn_status",
        "type": "function",
        "z": "phase3_tab",
        "name": "Sensor connection indicators",
        "func": "const session = flow.get(\"session\");\nif (!session) return null;\nconst now = Date.now();\nconst lastSeen = flow.get(\"lastSeen\") || {};\nconst timeout = 15000;\nfunction status(name, key) {\n    const ok = (now - (lastSeen[key] || 0)) < timeout;\n    const color = ok ? \"#00b500\" : \"#ca3838\";\n    const label = ok ? \"Connected\" : \"Offline\";\n    return \"<span style='color:\" + color + \";font-size:18px'>&#9679;</span> <b>\" + name + \":</b> \" + label;\n}\nmsg.payload = status(\"Temperature\", \"temperature\") + \" &nbsp;&nbsp;&nbsp; \" + status(\"Humidity\", \"humidity\");\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 460,
        "y": 480,
        "wires": [
            [
                "p3_text_conn"
            ]
        ]
