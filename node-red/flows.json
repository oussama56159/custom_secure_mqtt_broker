    {
        "id": "p3_ui_form_login",
        "type": "ui_form",
        "z": "phase3_tab",
        "name": "",
        "label": "Dashboard login",
        "group": "p3_ui_grp_login",
        "order": 1,
        "width": 6,
        "height": 1,
        "options": [
            {
                "label": "Username",
                "value": "username",
                "type": "text",
                "required": true
            },
            {
                "label": "Password",
                "value": "password",
                "type": "password",
                "required": true
            }
        ],
        "formValue": {
            "username": "",
            "password": ""
        },
        "payload": "",
        "submit": "Login",
        "cancel": "Clear",
        "topic": "login",
        "x": 170,
        "y": 80,
        "wires": [
            [
                "p3_fn_auth"
            ]
        ]
    },
    {
        "id": "p3_fn_auth",
        "type": "function",
        "z": "phase3_tab",
        "name": "Authenticate user",
        "func": "const USERS = {\n    admin:    { password: \"admin123\",    role: \"admin\",    label: \"Admin\" },\n    operator: { password: \"operator123\", role: \"operator\", label: \"Operator\" },\n    viewer:   { password: \"viewer123\",   role: \"viewer\",   label: \"Viewer\" }\n};\nconst SESSION_MS = 30 * 60 * 1000;\nconst username = (msg.payload.username || \"\").trim().toLowerCase();\nconst password = msg.payload.password || \"\";\nconst user = USERS[username];\nif (!user || user.password !== password) {\n    return [null, { payload: \"<span style='color:#ff5252'>Invalid username or password</span>\" }];\n}\nconst session = {\n    username,\n    role: user.role,\n    label: user.label,\n    loginTime: Date.now(),\n    expiresAt: Date.now() + SESSION_MS\n};\nflow.set(\"session\", session);\nconst tabShow = {\n    admin: [\"p3_ui_tab_dashboard\", \"p3_ui_tab_charts\", \"p3_ui_tab_messages\", \"p3_ui_tab_security\", \"p3_ui_tab_logs\"],\n    operator: [\"p3_ui_tab_dashboard\", \"p3_ui_tab_charts\", \"p3_ui_tab_messages\", \"p3_ui_tab_security\"],\n    viewer: [\"p3_ui_tab_dashboard\", \"p3_ui_tab_charts\"]\n};\nconst show = tabShow[user.role] || [];\nconst hide = [\"p3_ui_tab_login\"];\nconst groupShow = {\n    admin: [\"p3_ui_grp_sec_basic\", \"p3_ui_grp_sec_advanced\"],\n    operator: [\"p3_ui_grp_sec_basic\"],\n    viewer: []\n};\nconst groupHide = {\n    admin: [],\n    operator: [\"p3_ui_grp_sec_advanced\"],\n    viewer: [\"p3_ui_grp_sec_basic\", \"p3_ui_grp_sec_advanced\", \"p3_ui_grp_messages\"]\n};\nconst ctrl = {\n    payload: {\n        tab: { show, hide },\n        group: { show: groupShow[user.role] || [], hide: groupHide[user.role] || [] }\n    }\n};\nreturn [ctrl, { payload: \"<span style='color:#00b500'>Welcome, \" + user.label + \"!</span>\" }];",
        "outputs": 2,
        "noerr": 0,
        "x": 420,
        "y": 80,
        "wires": [
            [
                "p3_ui_control"
            ],
            [
                "p3_text_login_err"
            ]
        ]
    },
    {
        "id": "p3_text_login_err",
        "type": "ui_text",
        "z": "phase3_tab",
