    {
        "id": "p3_fn_session_bar",
        "type": "function",
        "z": "phase3_tab",
        "name": "Update session bar",
        "func": "const session = flow.get(\"session\");\nif (!session) {\n    msg.payload = \"Not logged in\";\n    return msg;\n}\nconst remaining = Math.max(0, Math.ceil((session.expiresAt - Date.now()) / 60000));\nmsg.payload = \"Logged in as <b>\" + session.username + \"</b> (\" + session.label + \") &mdash; \" + remaining + \" min remaining\";\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 420,
        "y": 200,
        "wires": [
            [
                "p3_text_session"
            ]
        ]
    },
    {
        "id": "p3_inj_session_check",
        "type": "inject",
        "z": "phase3_tab",
        "name": "Session timeout check",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "60",
        "once": false,
        "payload": "",
        "payloadType": "date",
        "x": 180,
        "y": 240,
        "wires": [
            [
                "p3_fn_session_check"
            ]
        ]
    },
    {
        "id": "p3_fn_session_check",
        "type": "function",
        "z": "phase3_tab",
        "name": "Expire stale sessions",
        "func": "const session = flow.get(\"session\");\nif (!session) return null;\nif (Date.now() > session.expiresAt) {\n    flow.set(\"session\", null);\n    node.warn(\"Session expired for \" + session.username);\n    return {\n        payload: {\n            tab: {\n                show: [\"p3_ui_tab_login\"],\n                hide: [\"p3_ui_tab_dashboard\", \"p3_ui_tab_charts\", \"p3_ui_tab_messages\", \"p3_ui_tab_security\", \"p3_ui_tab_logs\"]\n            }\n        }\n    };\n}\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "x": 440,
        "y": 240,
        "wires": [
            [
                "p3_ui_control"
            ]
        ]
    },
    {
        "id": "p3_inj_temp",
        "type": "inject",
        "z": "phase3_tab",
        "name": "Simulate temperature every 5s",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "once": true,
        "onceDelay": 1,
        "payload": "",
        "payloadType": "date",
        "x": 180,
        "y": 300,
        "wires": [
            [
                "p3_fn_temp"
            ]
        ]
    },
    {
        "id": "p3_fn_temp",
        "type": "function",
        "z": "phase3_tab",
        "name": "Build temperature payload",
        "func": "const value = Number((20 + Math.random() * 10).toFixed(1));\nmsg.topic = \"sensors/temperature\";\nmsg.payload = JSON.stringify({\n    sensor: \"temperature_sensor\",\n    temperature_c: value,\n    timestamp: new Date().toISOString()\n});\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 450,
        "y": 300,
        "wires": [
            [
                "p3_out_temp"
            ]
        ]
    },
    {
        "id": "p3_out_temp",
        "type": "mqtt out",
        "z": "phase3_tab",
        "name": "Publish temperature",
        "topic": "",
        "qos": "0",
        "retain": "false",
        "broker": "p3_mqtt_temp",
        "x": 710,
        "y": 300,
        "wires": []
    },
    {
